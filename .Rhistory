install.packages("webexercises")
library(webexercises)
library(learnr)
library(webexercises)
knitr::opts_chunk$set(echo = TRUE)
library(DBI)
library(duckdb)
library(tidyverse)
# 1. Read your CSV
mydata <- read.csv("data/nhanes.csv")
nhanes_demographics <- read.csv("data/nhanes_demographics.csv")
nhanes_health <- read.csv("data/nhanes_health.csv")
nhanes_set1<- read.csv("data/nhanes_set1.csv")
nhanes_set2<- read.csv("data/nhanes_set2.csv")
# 2. Create an in-memory SQLite database
con <- dbConnect(duckdb::duckdb(), dbdir = ":memory:")
# 3. Write the CSV into a SQL table
dbWriteTable(con, "nhanes", mydata)
dbWriteTable(con, "nhanes_demographics", nhanes_demographics)
dbWriteTable(con, "nhanes_health", nhanes_health)
dbWriteTable(con, "nhanes_set1", nhanes_set1)
dbWriteTable(con, "nhanes_set2", nhanes_set2)
